# ergo-rust-sync-dashboard - example configuration
# Copy this file to .env and adjust as needed.

# Rust node API endpoint.
# This is the local or SSH-tunneled API of the ergo-node-rust instance you want to monitor.
ERGO_RUST_NODE_URL=http://127.0.0.1:9052

# Reference Ergo node API for comparison against the Rust node.
# The default below is a public community seed node (Toronto).
# Replace with any reachable Ergo node /info endpoint.
ERGO_RUST_REFERENCE_URL=http://159.89.116.15:11088

# Optional label shown in the UI for the reference source.
# If left blank, auto-derives from ERGO_RUST_REFERENCE_URL.
ERGO_RUST_REFERENCE_LABEL=

# Refresh interval in milliseconds.
ERGO_RUST_REFRESH_MS=2000

# Optional SSH host alias for remote service-uptime probing.
# Leave blank for local systemd (works when the Rust node runs on the same machine as the display).
# Example: ERGO_RUST_UPTIME_SSH_HOST=my-ergo-node
ERGO_RUST_UPTIME_SSH_HOST=

# Optional: override the systemd unit name used for uptime probing.
# Default: ergo-node-rust.service
ERGO_RUST_SERVICE_NAME=
